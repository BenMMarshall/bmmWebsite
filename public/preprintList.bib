	month = mar,
	year = {2026},
	file = {Accepted Version:C\:\\Users\\benja\\Zotero\\storage\\CUW5S93X\\Cooper et al. - 2026 - Data- and code-archiving in the British Ecological Society journals present status and recommendati.pdf:application/pdf;PDF:C\:\\Users\\benja\\Zotero\\storage\\GH9L74UJ\\Cooper et al. - 2026 - Data- and code-archiving in the British Ecological Society journals present status and recommendati.pdf:application/pdf},
